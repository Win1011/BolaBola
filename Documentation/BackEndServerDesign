## 8. Suggested Database Schema

### 8.1 users

```sql
create table users (
  id uuid primary key,
  apple_sub text unique not null,
  app_account_token uuid unique not null,
  display_name text,
  email_relay text,
  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now(),
  last_login_at timestamptz
);
```

说明：

- `email_relay` 可为空
- `display_name` 是 Bola 账号展示名，不等于宠物名

### 8.2 user_sessions

```sql
create table user_sessions (
  id uuid primary key,
  user_id uuid not null references users(id) on delete cascade,
  refresh_token_hash text not null,
  device_id text,
  platform text not null,
  created_at timestamptz not null default now(),
  expires_at timestamptz not null,
  revoked_at timestamptz
);
```

### 8.3 devices

```sql
create table devices (
  id uuid primary key,
  user_id uuid not null references users(id) on delete cascade,
  device_id text not null,
  platform text not null,
  app_version text,
  build_number text,
  last_seen_at timestamptz,
  unique(user_id, device_id, platform)
);
```

### 8.4 subscriptions

```sql
create table subscriptions (
  id uuid primary key,
  user_id uuid not null references users(id) on delete cascade,
  product_id text not null,
  original_transaction_id text not null unique,
  latest_transaction_id text,
  app_account_token uuid,
  status text not null,
  environment text not null,
  purchased_at timestamptz,
  expires_at timestamptz,
  grace_period_expires_at timestamptz,
  revoked_at timestamptz,
  raw_last_payload jsonb,
  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now()
);
```

`status` 建议值：

- `active`
- `grace_period`
- `billing_retry`
- `expired`
- `revoked`
- `refunded`

### 8.5 user_entitlements

```sql
create table user_entitlements (
  id uuid primary key,
  user_id uuid not null references users(id) on delete cascade,
  entitlement_code text not null,
  is_active boolean not null,
  source text not null,
  starts_at timestamptz,
  expires_at timestamptz,
  updated_at timestamptz not null default now(),
  unique(user_id, entitlement_code)
);
```

### 8.6 pets

```sql
create table pets (
  id uuid primary key,
  user_id uuid not null unique references users(id) on delete cascade,
  display_name text not null default 'Bola',
  companion_value double precision not null default 0,
  core_state text,
  max_ever_companion_value double precision,
  last_synced_at timestamptz,
  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now()
);
```

### 8.7 pet_state_snapshots

```sql
create table pet_state_snapshots (
  id uuid primary key,
  user_id uuid not null references users(id) on delete cascade,
  device_id text,
  snapshot_kind text not null,
  payload jsonb not null,
  device_timestamp timestamptz,
  server_received_at timestamptz not null default now()
);
```

### 8.8 diary_entries

```sql
create table diary_entries (
  id uuid primary key,
  user_id uuid not null references users(id) on delete cascade,
  created_at timestamptz not null,
  title text not null,
  summary text not null,
  emoji text,
  source_text text,
  updated_at timestamptz not null default now()
);
```

### 8.9 life_records

```sql
create table life_records (
  id uuid primary key,
  user_id uuid not null references users(id) on delete cascade,
  kind text not null,
  title text not null,
  subtitle text,
  detail_note text,
  icon_emoji text,
  created_at timestamptz not null,
  updated_at timestamptz not null default now()
);
```

### 8.10 meal_slots

```sql
create table meal_slots (
  id uuid primary key,
  user_id uuid not null references users(id) on delete cascade,
  slot_key text not null,
  hour int not null,
  minute int not null,
  updated_at timestamptz not null default now(),
  unique(user_id, slot_key)
);
```

### 8.11 app_store_notifications

```sql
create table app_store_notifications (
  id uuid primary key,
  notification_uuid text unique,
  notification_type text,
  subtype text,
  original_transaction_id text,
  app_account_token uuid,
  signed_payload text not null,
  processed_at timestamptz,
  created_at timestamptz not null default now()
);
```

### 8.12 ai_request_logs

```sql
create table ai_request_logs (
  id uuid primary key,
  user_id uuid references users(id) on delete set null,
  provider text not null,
  model text not null,
  endpoint text not null,
  request_tokens int,
  response_tokens int,
  status_code int,
  latency_ms int,
  created_at timestamptz not null default now()
);
```

